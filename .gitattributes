# Normalize line endings to LF in the repo; Git checks out platform-native
* text=auto eol=lf

# Windows-only scripts keep CRLF
*.bat text=auto eol=crlf
*.cmd text=auto eol=crlf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.ttf binary
*.woff binary
*.woff2 binary
