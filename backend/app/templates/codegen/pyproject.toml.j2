[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "mcp-{{ slug }}"
version = "1.0.0"
description = "{{ description | default('Generated MCP server for ' + name) }}"
requires-python = ">=3.11"
dependencies = [
    "mcp[cli]>=1.6.0",
    "httpx>=0.27.0",
    "pydantic>=2.0.0",
    "python-dotenv>=1.0.1",
]

[project.scripts]
serve = "src.server:main"

[tool.ruff]
line-length = 100
target-version = "py311"
