# === Core ===
ENV=development

# === Database ===
POSTGRES_PASSWORD=lanara_supersecret
DATABASE_URL=postgresql+asyncpg://lanara:lanara_supersecret@localhost:5432/lanara

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === MCP Servers ===
MCP_SPM_URL=http://localhost:8001/mcp

# === AI Models ===
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# === Secret Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
SECRET_ENCRYPTION_KEY=

# === Internal service secrets ===
# Shared secret for MCP servers calling POST /api/signals/ingest
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_INGEST_SECRET=

# === Auth (Phase 3) ===
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# === LiteLLM (Phase 2) ===
LITELLM_MASTER_KEY=sk-1234567890abcdef
OPENAI_API_KEY=sk-...

# === Observability (Phase 4) ===
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
