{
  "openapi": "3.0.0",
  "info": { "title": "OneOf Test", "version": "1.0.0" },
  "paths": {
    "/items": {
      "post": {
        "operationId": "createItem",
        "summary": "Create an item with a union-typed field",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "oneOf": [
                      { "type": "string" },
                      { "type": "integer" }
                    ]
                  },
                  "tag": { "type": "string" }
                },
                "required": ["data"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" }
        }
      }
    }
  }
}
